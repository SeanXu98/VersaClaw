# ============================================
# VersaClaw Environment Configuration
# ============================================
# Copy this file to .env.local and customize

# ============================================
# Nanobot Configuration
# ============================================

# Nanobot home directory (default: ~/.nanobot)
# This is where Nanobot stores its configuration and data
NANOBOT_HOME=/home/your-username/.nanobot

# ============================================
# Backend API Configuration
# ============================================

# Nanobot API Server URL
# For local development:
NANOBOT_API_URL=http://localhost:18790

# For Docker deployment (internal communication):
# NANOBOT_API_URL=http://backend:18790

# API Server host binding (default: 0.0.0.0)
NANOBOT_API_HOST=0.0.0.0

# API Server port (default: 18790)
NANOBOT_API_PORT=18790

# ============================================
# Application Settings
# ============================================

NEXT_PUBLIC_APP_NAME=VersaClaw
NEXT_PUBLIC_APP_DESCRIPTION=基于Nanobot扩展的AI Agent

# ============================================
# Security (Optional - currently no auth)
# ============================================

# ADMIN_PASSWORD=your-secure-password

# ============================================
# Development
# ============================================

NODE_ENV=development

# ============================================
# Docker Deployment Settings
# ============================================

# Frontend port (default: 5000)
FRONTEND_PORT=5000

# Backend API port (default: 18790)
BACKEND_PORT=18790

# Data persistence - use host path or named volume
# Uncomment to use host path:
# NANOBOT_DATA_PATH=/home/your-username/.nanobot
